const port = Number(process.env.{{envPrefix}}_PORT ?? 9360);

export default {
  mode: 'manual',
  port,
  pm2: {
    script: './service/server.js',
    env: {
      PORT: String(port),
    },
    autorestart: true,
  },
  urls({ host }) {
    return {
      openUrl: `http://${host}:${port}/`,
      healthUrl: `http://${host}:${port}/health`,
    };
  },
};

